{
  "Collector": {
    "DeviceId": "simulator-001",
    "FactoryId": "factory-001",
    "WorkshopId": "workshop-001",
    "TenantId": "default",
    "PollIntervalMs": 2000,
    "Modbus": {
      "Host": "127.0.0.1",
      "Port": 5020,
      "SlaveId": 1,
      "ReconnectIntervalMs": 5000,
      "ReadTimeoutMs": 3000,
      "ConnectTimeoutMs": 5000
    },
    "Mqtt": {
      "Enabled": true,
      "Broker": "localhost",
      "Port": 1883,
      "TopicPrefix": "amgateway",
      "ClientId": "AmGatewayCloud-Modbus",
      "UseTls": false
    },
    "RegisterGroups": [
      {
        "Name": "sensors",
        "Type": "Holding",
        "Start": 0,
        "Count": 10,
        "ScaleFactor": 10.0,
        "TagScales": {
          "rpm": 1.0,
          "current": 100.0,
          "frequency": 100.0
        },
        "Tags": [
          "temperature", "pressure", "flow", "liquidLevel", "humidity",
          "rpm", "voltage", "current", "power", "frequency"
        ]
      },
      {
        "Name": "parameters",
        "Type": "Holding",
        "Start": 10,
        "Count": 10,
        "ScaleFactor": 1.0,
        "TagScales": {
          "noise": 100.0,
          "alarmHighLimit": 10.0,
          "alarmLowLimit": 10.0,
          "powerFactor": 100.0
        },
        "Tags": [
          "mode", "noise", "delay", "samplePeriod", "alarmHighLimit",
          "alarmLowLimit", "deviceAddress", "baudRate", "powerFactor", "reserved"
        ]
      },
      {
        "Name": "statistics",
        "Type": "Holding",
        "Start": 20,
        "Count": 10,
        "ScaleFactor": 10.0,
        "TagScales": {
          "runHours": 1.0,
          "startCount": 1.0,
          "commCount": 1.0,
          "errorCount": 1.0,
          "statReserved1": 1.0,
          "statReserved2": 1.0
        },
        "Tags": [
          "tempMax", "tempMin", "tempAvg", "pressureStat",
          "runHours", "startCount", "commCount", "errorCount",
          "statReserved1", "statReserved2"
        ]
      },
      {
        "Name": "alarms",
        "Type": "Holding",
        "Start": 100,
        "Count": 7,
        "ScaleFactor": 1.0,
        "Tags": [
          "faultInject", "alarmEnable", "alarmStatus",
          "faultCode1", "faultCode2", "faultCode3", "faultCode4"
        ]
      },
      {
        "Name": "discretes",
        "Type": "Discrete",
        "Start": 0,
        "Count": 7,
        "Tags": [
          "isRunning", "isAlarm", "isOverLimit",
          "isCommOk", "isLocal", "isRemote", "discreteReserved"
        ]
      },
      {
        "Name": "coils",
        "Type": "Coil",
        "Start": 0,
        "Count": 7,
        "Tags": [
          "runControl", "alarmAck", "reset",
          "enable1", "enable2", "enable3", "enable4"
        ]
      }
    ]
  }
}
