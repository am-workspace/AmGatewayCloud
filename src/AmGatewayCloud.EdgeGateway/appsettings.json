{
  "EdgeGateway": {
    "HubId": "edgehub-a",
    "FactoryId": "factory-a",
    "WorkshopId": "workshop-1",
    "TenantId": "default",

    "Mqtt": {
      "Broker": "localhost",
      "Port": 1883,
      "TopicFilter": "amgateway/#",
      "UseSharedSubscription": false,
      "SharedGroup": "edgehub",
      "ClientId": "AmGatewayCloud-EdgeHub",
      "UseTls": false,
      "QoS": 1,
      "KeepAliveSeconds": 60,
      "CleanSession": false
    },

    "InfluxDb": {
      "Url": "http://localhost:8086",
      "Token": "dev-token-amgateway-edge",
      "Org": "amgateway",
      "Bucket": "edge-data",
      "RetentionHours": 168,
      "BatchSize": 100,
      "FlushIntervalMs": 1000
    },

    "RabbitMq": {
      "HostName": "localhost",
      "Port": 5672,
      "UseSsl": false,
      "VirtualHost": "/",
      "Username": "guest",
      "Password": "guest",
      "Exchange": "amgateway.topic",
      "QueueName": "amgateway.{factoryId}",
      "RoutingKeyTemplate": "amgateway.{factoryId}.{workshopId}.{deviceId}.{protocol}",
      "ReconnectDelayMs": 5000,
      "MaxReconnectDelayMs": 60000,
      "PrefetchCount": 50
    }
  }
}
