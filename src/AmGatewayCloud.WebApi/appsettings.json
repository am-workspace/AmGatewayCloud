{
  "Jwt": {
    "Secret": "amgateway-dev-secret-key-at-least-32-characters-long!"
  },
  "DefaultTenantId": "default",
  "WebApi": {
    "CorsOrigins": [ "http://localhost:5173" ],
    "RabbitMq": {
      "HostName": "localhost",
      "Port": 5672,
      "UseSsl": false,
      "VirtualHost": "/business",
      "Username": "guest",
      "Password": "guest",
      "Exchange": "amgateway.alarms",
      "QueueName": "amgateway.alarm-notifications",
      "ReconnectDelayMs": 5000,
      "MaxReconnectDelayMs": 60000
    }
  },

  "ReverseProxy": {
    "Clusters": {
      "alarm-service": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "workorder-service": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:5002"
          }
        }
      }
    },
    "Routes": {
      "alarm-rules-route": {
        "ClusterId": "alarm-service",
        "Match": {
          "Path": "/api/alarmrules/{**catch-all}"
        }
      },
      "alarms-route": {
        "ClusterId": "alarm-service",
        "Match": {
          "Path": "/api/alarms/{**catch-all}"
        }
      },
      "workorders-route": {
        "ClusterId": "workorder-service",
        "Match": {
          "Path": "/api/workorders/{**catch-all}"
        }
      }
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "RabbitMQ": "Warning",
        "Yarp": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  }
}
